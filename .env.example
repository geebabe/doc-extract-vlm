PROJECT_NAME="OCR API"
VLLM_BASE_URL="https://your-vllm-server-url/v1"
VLLM_MODEL_NAME="Qwen/Qwen3-VL-2B-Instruct"
VLLM_API_KEY="your-api-key"

OCR_LANG="vi"
OCR_VERSION="PP-OCRv5"
OCR_TEXT_REC_SCORE_THRESH="0.5"

# Debug dumps: when true, OCR text, prompts, and raw VLM responses are
# written to DEBUG_DUMP_DIR for every request whose extraction is all-null
# (or any request that errors). Useful for triaging cases like the
# "success=true but data is all null" ID-card failure mode.
DEBUG_DUMP_ENABLED="false"
DEBUG_DUMP_DIR="debug_dumps"